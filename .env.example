ANTHROPIC_API_KEY=your_key_here
TELEGRAM_TOKEN=your_token_here
ADMIN_TELEGRAM_ID=your_telegram_user_id

NEXT_PUBLIC_SUPABASE_URL=your_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_key_here
DATABASE_URL=your_database_url_here

CLAUDE_RANDOM_CHANCE=0.10
CLAUDE_CONTEXT_MESSAGES=20
CLAUDE_MAX_TOKENS=8000

# Conversation mode: "session" (new) or "thread" (legacy)
CONVERSATION_MODE=session

# Session settings
DEBOUNCE_MS=14000
SESSION_TIMEOUT_MINUTES=10

GROQ_API_KEY=your_key_here

# Classifier log chat (sends classification results to this Telegram chat)
CLASSIFIER_LOG_CHAT_ID=your_chat_id_here

# ElevenLabs TTS (for send_voice tool)
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Kill switch: skip all processing (clears Telegram retry queue)
SKIP_PROCESSING=false

# History window: controls raw message window, chunk size, and chunk count
HISTORY_WINDOW=50
